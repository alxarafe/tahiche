meta {
  name: 02-list-suppliers
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}{{apiBase}}/proveedores
  body: none
  auth: none
}

headers {
  Token: {{apiKey}}
}

tests {
  test("Status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Returns array", function() {
    const data = res.getBody();
    expect(data).to.be.an('array');
  });
}
