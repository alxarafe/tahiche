meta {
  name: 01-create-agent
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}{{apiBase}}/agentes
  body: json
  auth: none
}

headers {
  Token: {{apiKey}}
  Content-Type: application/json
}

body:json {
  {
    "nombre": "API Test Agent",
    "dnicif": "12345678Z",
    "email": "agent@test.com",
    "telefono1": "555-0001"
  }
}

tests {
  test("Status 200 (created)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Confirmation with data", function() {
    const data = res.getBody();
    expect(data).to.have.property('ok');
    if (data.data && data.data.codagente) {
      bru.setEnvVar("testAgentId", data.data.codagente);
    }
  });
}
