meta {
  name: 01-create-family
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}{{apiBase}}/familias
  body: json
  auth: none
}

headers {
  Token: {{apiKey}}
  Content-Type: application/json
}

body:json {
  {
    "codfamilia": "TST",
    "descripcion": "Test Family"
  }
}

tests {
  test("Status 200 (created)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Confirmation", function() {
    const data = res.getBody();
    expect(data).to.have.property('ok');
  });
}
