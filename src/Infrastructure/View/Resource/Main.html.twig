{% extends "@Core/Master/MenuTemplate.html.twig" %}

{% block body %}
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                    <h1 class="mb-0">{{ i18n.trans(mode) }}</h1>
                    <div>
                        {% for btn in buttons %}
                            {% if btn.action == 'submit' %}
                                <button type="submit" form="resource-form" class="btn btn-{{ btn.type }}">
                                    <i class="{{ btn.icon }}"></i> {{ btn.label }}
                                </button>
                            {% else %}
                                <a href="{{ btn.target }}" class="btn btn-{{ btn.type }}">
                                    <i class="{{ btn.icon }}"></i> {{ btn.label }}
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                {% for msg in messages %}
                    <div class="alert alert-{{ msg.level | default('info') }} alert-dismissible fade show" role="alert">
                        {{ msg.text }}
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                {% endfor %}
                
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        {% if mode == 'list' %}
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            {% for column in struct.list.tabs[activeTab].columns %}
                                                <th>{{ column.label }}</th>
                                            {% endfor %}
                                            <th class="text-right">{{ i18n.trans('actions') }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for row in listData.data %}
                                            <tr>
                                                {% for column in struct.list.tabs[activeTab].columns %}
                                                    <td>{{ attribute(row, column.field) }}</td>
                                                {% endfor %}
                                                <td class="text-right">
                                                    <a href="{{ action }}&id={{ attribute(row, primaryColumn) }}" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="{{ struct.list.tabs[activeTab].columns | length + 1 }}" class="text-center py-4 text-muted">
                                                    <i class="fas fa-info-circle"></i> {{ i18n.trans('no-results-found') }}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <form id="resource-form" action="{{ action }}{% if recordId %}&id={{ recordId }}{% endif %}" method="post" class="p-4">
                                <input type="hidden" name="action" value="save"/>
                                {{ formToken() | raw }}
                                
                                <div class="row">
                                    {% for sectionId, section in struct.edit.sections %}
                                        <div class="col-md-{{ section.col | default(6) }}">
                                            <fieldset class="mb-4">
                                                <legend class="h5 border-bottom pb-2 mb-3">{{ section.title }}</legend>
                                                {% for field in section.fields %}
                                                    <div class="form-group mb-3">
                                                        <label class="form-label font-weight-bold">{{ field.label }}</label>
                                                        {% if field.type == 'text' %}
                                                            <input type="text" name="data[{{ field.field }}]" value="{{ attribute(record, field.field) }}" 
                                                                   class="form-control" {% if field.required %}required{% endif %}>
                                                        {% elseif field.type == 'integer' %}
                                                            <input type="number" name="data[{{ field.field }}]" value="{{ attribute(record, field.field) }}" 
                                                                   class="form-control" {% if field.required %}required{% endif %}>
                                                        {% endif %}
                                                    </div>
                                                {% endfor %}
                                            </fieldset>
                                        </div>
                                    {% endfor %}
                                <div class="mt-4 border-top pt-3 text-end">
                                    <button type="submit" class="btn btn-primary px-4">
                                        <i class="fas fa-save me-2"></i>Guardar
                                    </button>
                                </div>
                            </form>
                        {% endif %}
                    </div>
                </div>
                
                {% if mode == 'list' and listData.total > struct.list.limit %}
                    <div class="mt-3 text-center">
                        <p class="text-muted small">Total: {{ listData.total }} registros</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
