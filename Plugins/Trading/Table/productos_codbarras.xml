<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
    </column>
    <column>
        <name>idvariante</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>codbarras</name>
        <type>character varying(128)</type>
        <null>NO</null>
    </column>
    <column>
        <name>tipo</name>
        <type>character varying(20)</type>
        <null>NO</null>
        <default>'EAN-13'</default>
    </column>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
        <null>NO</null>
        <default>1</default>
    </column>
    <column>
        <name>descripcion</name>
        <type>character varying(200)</type>
    </column>
    <column>
        <name>fechaalta</name>
        <type>timestamp</type>
    </column>
    <constraint>
        <name>productos_codbarras_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uniq_codbarras</name>
        <type>UNIQUE (codbarras)</type>
    </constraint>
    <constraint>
        <name>fk_prodbarras_variante</name>
        <type>FOREIGN KEY (idvariante) REFERENCES variantes (idvariante) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
