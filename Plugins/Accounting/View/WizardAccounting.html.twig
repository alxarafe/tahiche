{% extends "Master/MicroTemplate.html.twig" %}

{% block messages %}
    <div class="bg-primary pt-5 pb-5">
        <div class="container">
            <div class="row">
                <div class="col">{{ parent() }}</div>
            </div>
        </div>
        <br/>
        <br/>
        <br/>
    </div>
{% endblock %}

{% block body %}
    <div class="container" style="margin-top: -100px;">
        <form action="#" method="post" class="form" id="formWizardAccounting">
            {{ formToken() }}
            <input type="hidden" name="action" value="save"/>
            <div class="card shadow mb-5">
                <div class="card-body">
                    <h1 class="h3">
                        <i class="fa-solid fa-book me-2"></i> {{ trans('wizard-accounting') }}
                        <a href="{{ fsc.url() }}" class="btn btn-sm btn-outline-secondary float-end"
                           title="{{ trans('refresh') }}">
                            <i class="fa-solid fa-redo" aria-hidden="true"></i>
                        </a>
                    </h1>
                    <p>{{ trans('wizard-accounting-p') }}</p>
                    <hr/>
                    {% if fsc.hasPlan %}
                        <div class="row gx-2">
                            <div class="col-auto">
                                <div class="mb-3 form-check pe-3">
                                    <input type="checkbox" name="defaultplan" value="1" id="checkboxPlan"
                                           class="form-check-input" checked/>
                                    <label for="checkboxPlan">{{ trans('load-def-acc-plan') }}</label>
                                </div>
                            </div>
                        </div>
                        <div class="alert alert-info" role="alert">
                            <i class="fa-solid fa-info-circle me-1"></i>
                            {{ trans('wizard-accounting-info') }}
                        </div>
                    {% else %}
                        <div class="alert alert-warning" role="alert">
                            <i class="fa-solid fa-exclamation-triangle me-1"></i>
                            {{ trans('wizard-accounting-no-plan') }}
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer text-end">
                    <a href="Dashboard" class="btn btn-secondary me-2">
                        <i class="fa-solid fa-times me-1"></i> {{ trans('skip') }}
                    </a>
                    {% if fsc.hasPlan %}
                        <button type="submit" class="btn btn-primary" id="btnWizardAccounting">
                            <i class="fa-solid fa-save me-1"></i> {{ trans('load-def-acc-plan') }}
                        </button>
                    {% endif %}
                </div>
            </div>
        </form>
        <br/>
    </div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('Dinamic/Assets/CSS/custom.css') }}"/>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('node_modules/pace-js/pace.min.js') }}"></script>
    <script src="{{ asset('Dinamic/Assets/JS/Custom.js') }}"></script>
    <script>
        $(document).ready(function () {
            $("#formWizardAccounting").submit(function () {
                $("#btnWizardAccounting").prop('disabled', true);
                $("#btnWizardAccounting").html('<i class="fa-solid fa-circle-notch fa-spin"></i>');
            });
        });
    </script>
{% endblock %}
