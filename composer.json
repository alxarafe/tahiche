{
  "name": "alxarafe/tahiche",
  "type": "project",
  "description": "Open source ERP software. Built on modern PHP and bootstrap 5. Easy and powerful.",
  "homepage": "https://github.com/Alxarafe/tahiche",
  "license": "LGPL-3.0-or-later",
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es",
      "role": "Developer"
    }
  ],
  "config": {
    "platform": {
      "php": "8.2"
    },
    "process-timeout": 0,
    "minimum-stability": "dev",
    "prefer-stable": true
  },
  "require": {
    "vlucas/phpdotenv": "^5.6",
    "php": ">=8.2",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "ext-zip": "*",
    "mk-j/php_xlsxwriter": "0.39",
    "parsecsv/php-parsecsv": "1.*",
    "phpmailer/phpmailer": "6.*",
    "rospdf/pdf-php": "0.12.*",
    "twig/twig": "3.*",
    "globalcitizen/php-iban": "4.*",
    "pragmarx/google2fa": "^8.0",
    "chillerlan/php-qrcode": "^4.0",
    "alxarafe/resource-controller": "0.2.1",
    "alxarafe/resource-pdo": "0.1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "9.*",
    "squizlabs/php_codesniffer": "3.*",
    "phpstan/phpstan": "^1.12"
  },
  "autoload": {
    "psr-4": {
      "Tahiche\\Plugins\\": "Plugins/",
      "FacturaScripts\\Plugins\\": "Plugins/",
      "FacturaScripts\\Core\\": "Core/",
      "FacturaScripts\\Dinamic\\": "Dinamic/",
      "Tahiche\\Test\\": "Tests/",
      "Tahiche\\Tests\\": "Tests/",
      "Modules\\": "Modules/",
      "Tahiche\\Infrastructure\\": "src/Infrastructure/"
    }
  },
  "keywords": [
    "facturascripts",
    "php",
    "invoice",
    "erp",
    "crm",
    "billing",
    "accounting"
  ],
  "support": {
    "source": "https://github.com/Alxarafe/tahiche"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:coverage": "vendor/bin/phpunit --coverage-html coverage",
    "phpstan": "vendor/bin/phpstan analyse src",
    "cs-check": "vendor/bin/phpcs",
    "cs-fix": "vendor/bin/phpcbf",
    "dev-server": "php -S localhost:8000 index.php"
  }
}
