{#
/**
 * ResourceBridge.html.twig — Plantilla puente para controladores modernos.
 *
 * Extiende el layout legacy (MenuTemplate) para mantener la barra de
 * navegación, CSS/JS y la coherencia visual con el resto del ERP.
 * El contenido del ResourceController se inyecta en el bloque body.
 */
#}
{% extends "Master/MenuTemplate.html.twig" %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('alxarafe/assets/css/alxarafe.min.css') }}"/>
    <link rel="stylesheet" href="{{ asset('alxarafe/assets/css/alxarafe-content.css') }}"/>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('alxarafe/js/resource.bundle.js') }}"></script>
{% endblock %}

{% block body %}
    {{ resourceContent | raw }}
{% endblock %}
