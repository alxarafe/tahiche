{% extends "Master/MicroTemplate.html.twig" %}

{% block body %}
    {{ parent() }}
    <div class="login-page d-flex align-items-center justify-content-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-5 col-lg-4">
                    <form action="{{ asset('login') }}" method="post" class="form">
                        {{ formToken() }}
                        <input type="hidden" name="action" value="login">
                        
                        <div class="card login-card border-0 shadow-lg">
                            <div class="card-header border-0 bg-transparent text-center pt-5 pb-4">
                                <a href="{{ asset('login') }}">
                                    <img src="{{ asset('Assets/Images/logo-white.png') }}" alt="Tahiche ERP" class="img-fluid login-logo mb-3" style="max-height: 80px;">
                                </a>
                                <h4 class="fw-light text-white mt-2">Bienvenido a Tahiche</h4>
                            </div>
                            
                            <div class="card-body px-4 pb-5">
                                <p class="text-center text-light-emphasis mb-4 opacity-75">{{ trans('login-text') }}</p>
                                
                                <div class="mb-3">
                                    <div class="input-group input-group-modern">
                                        <span class="input-group-text bg-dark border-secondary">
                                            <i class="fa-solid fa-user text-info" aria-hidden="true"></i>
                                        </span>
                                        <input type="text" name="fsNick" class="form-control bg-dark text-white border-secondary" 
                                               maxlength="50" placeholder="{{ trans('user') }}" required autocomplete="off" autofocus/>
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    <div class="input-group input-group-modern">
                                        <span class="input-group-text bg-dark border-secondary">
                                            <i class="fa-solid fa-key text-info" aria-hidden="true"></i>
                                        </span>
                                        <input type="password" name="fsPassword" class="form-control bg-dark text-white border-secondary" 
                                               maxlength="50" placeholder="{{ trans('password') }}" required autocomplete="off"/>
                                    </div>
                                    <div class="text-end mt-2">
                                        <a href="#" class="text-info text-decoration-none small" data-bs-toggle="modal" data-bs-target="#newPasswordModal">
                                            {{ trans('i-forgot-password') }}
                                        </a>
                                    </div>
                                </div>
                                
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-info btn-lg py-3 fw-bold text-uppercase shadow-sm">
                                        <i class="fa-solid fa-right-to-bracket me-2"></i> {{ trans('login') }}
                                    </button>
                                </div>
                            </div>
                            
                            <div class="card-footer border-0 bg-dark-subtle text-center py-3">
                                <small class="text-muted">Tahiche ERP &copy; {{ "now"|date("Y") }}</small>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# Modal de nueva contraseña mantenido pero con estilos ajustados #}
    <form action="{{ asset('login') }}" method="post" class="form">
        {{ formToken() }}
        <input type="hidden" name="action" value="change-password">
        <div class="modal fade" id="newPasswordModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content bg-dark text-white border-secondary">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title">
                            <i class="fa-solid fa-user-lock me-2 text-info"></i> {{ trans('new-password') }}
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body px-4">
                        <a href="https://facturascripts.com/publicaciones/he-olvidado-mi-contrasena" rel="nofollow"
                           target="_blank" class="btn w-100 btn-link text-info mb-4">
                            {{ trans('need-help-password') }}
                        </a>
                        <div class="mb-3">
                            <input type="text" name="fsNewUserPasswd" class="form-control bg-black text-white border-secondary" 
                                   maxlength="50" placeholder="{{ trans('user') }}" required autocomplete="off"/>
                        </div>
                        <div class="mb-3">
                            <input type="password" name="fsNewPasswd" class="form-control bg-black text-white border-secondary" 
                                   maxlength="50" placeholder="{{ trans('new-password') }}" required autocomplete="off"/>
                        </div>
                        <div class="mb-3">
                            <input type="password" name="fsNewPasswd2" class="form-control bg-black text-white border-secondary" 
                                   maxlength="50" placeholder="{{ trans('repeat-new-password') }}" required autocomplete="off"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">{{ trans('database') }}</label>
                            <input type="password" name="fsDbPasswd" class="form-control bg-black text-white border-secondary"
                                   placeholder="{{ trans('db-password') }}" autocomplete="off"/>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary">
                        <button type="submit" class="btn btn-info w-100">{{ trans('save') }}</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}

{% block css %}
    {{ parent() }}
    <style>
        .login-page {
            min-height: 100vh;
            background: radial-gradient(circle at center, #1a2a6c, #b21f1f, #fdbb2d);
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            font-family: 'Inter', sans-serif;
        }
        
        .login-card {
            background: rgba(15, 23, 42, 0.8) !important;
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: 20px !important;
            overflow: hidden;
        }
        
        .input-group-modern {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .input-group-modern .input-group-text {
            border: none;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
        
        .input-group-modern .form-control {
            border: none;
            padding: 0.75rem 1rem;
        }
        
        .input-group-modern .form-control:focus {
            box-shadow: none;
            background-color: #000 !important;
        }
        
        .btn-info {
            background: linear-gradient(90deg, #00d2ff 0%, #3a7bd5 100%);
            border: none;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        
        .btn-info:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(58, 123, 213, 0.4);
            background: linear-gradient(90deg, #3a7bd5 0%, #00d2ff 100%);
        }
        
        .login-logo {
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
            transition: transform 0.5s ease;
        }
        
        .login-logo:hover {
            transform: scale(1.05);
        }

        .text-light-emphasis {
            color: #cbd5e1 !important;
        }
    </style>
{% endblock %}